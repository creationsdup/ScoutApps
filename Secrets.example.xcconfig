// Template for Secrets.xcconfig (which is gitignored).
//
// Setup: copy this file to `Secrets.xcconfig` and paste your Supabase `anon`
// key. Get it from CampManager/apps/web/.env.local → NEXT_PUBLIC_SUPABASE_ANON_KEY.
//
//   cp Secrets.example.xcconfig Secrets.xcconfig
//
// The key is injected into the generated Info.plist at build time and read by
// Config.swift. If Secrets.xcconfig is missing, the app builds but shows a
// "clé Supabase manquante" message instead of connecting.

SUPABASE_ANON_KEY = PASTE_YOUR_ANON_KEY_HERE
